<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>PLib</id>
    <version>4.24.0</version>
    <title>PeterHan.PLib</title>
    <authors>Peter Han (https://github.com/peterhaneve)</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>icon.png</icon>
    <projectUrl>https://github.com/peterhaneve/ONIMods</projectUrl>
    <description>PLib - Peter Han's library used for creating mods for Oxygen Not Included, a simulation game by Klei Entertainment.
    
Contains methods aimed at improving cross-mod compatibility, in-game user interfaces, and game-wide functions such as Actions and Lighting. An easy-to-use Mod Options menu is also included.</description>
    <releaseNotes>StringOptionsEntry default width can now be customized for manually created instances.
        
Migrate legacy target version from netframework471 to net48. The primary version will remain netstandard2.1.</releaseNotes>
    <copyright>Copyright 2025 Peter Han</copyright>
    <tags>Game, OxygenNotIncluded, Oxygen, PLib, Library</tags>
    <repository type="git" commit="5ff529e709ee7933faf92910e1028a918e029a84" />
    <dependencies>
      <group targetFramework=".NETFramework4.8" />
      <group targetFramework=".NETStandard2.1">
        <dependency id="Lib.Harmony.Ref" version="2.4.2" exclude="Build,Analyzers" />
      </group>
    </dependencies>
    <frameworkAssemblies>
      <frameworkAssembly assemblyName="System.IO.Compression, Version=4.2.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" targetFramework=".NETFramework4.8" />
      <frameworkAssembly assemblyName="System.Reflection.Emit.ILGeneration, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" targetFramework=".NETFramework4.8" />
    </frameworkAssemblies>
  </metadata>
</package>